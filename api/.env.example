# ─────────────────────────────────────────────────────────────────────────────
# api/.env  →  read by the Python FastAPI service (app.config Settings)
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `api/.env` (gitignored). The Node sidecar has its own repo-root .env
# (see ../.env.example). Both must exist on the droplet; the deploy never touches
# them (gitignored), so set them by hand once.

# Postgres DSN. On prod point at the real DB (migrations run on deploy). Locally a
# closed port makes asyncpg fail fast → app degrades to stateless matching.
DATABASE_URL=

EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DEVICE=cpu

# DentalKart admin catalog API (pull random SKUs for scheduled runs).
DK_ADMIN_API_KEY=

# Scheduler. Keep 0 — runs are triggered manually, not on a timer.
SCHEDULED_RUNS_ENABLED=0

# SerpAPI — Google-Shopping discovery for the top-N competitors (/serp/* only;
# does NOT affect /compare). Must be set + enabled on prod for the Google feature
# to work the same as local. Free plan = 250 searches/month; a compare spends ~3–8.
SERPAPI_KEY=
SERP_ENABLED=1

# LLM borderline judge — empty = disabled (rules only). Needs a paid Anthropic API
# key (Max plan does NOT cover the API). Leave empty unless/until a key is provided.
ANTHROPIC_API_KEY=
